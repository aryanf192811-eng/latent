# Backend Environment Variables
PORT=5000
NODE_ENV=development # Change to production when deployed

# Database Configuration (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/latent

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL for CORS (Vercel URL)
FRONTEND_URL=https://latent-frontend.vercel.app

# Razorpay Integration (Optional for local dev, Required for production)
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=your_razorpay_secret
